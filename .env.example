# .env.example
# Copy this to .env and adjust values for your environment

# Ollama settings
EVALCI_OLLAMA_URL=http://localhost:11434
EVALCI_JUDGE_MODEL=mistral
EVALCI_JUDGE_TIMEOUT_SECONDS=25

# Dataset and config paths
EVALCI_DATASET_PATH=example/golden_dataset.json
EVALCI_CONFIG_PATH=evalci.yaml

# Database
EVALCI_DB_URL=sqlite+aiosqlite:///./evalci.db

# CI metadata (injected automatically by GitHub Actions)
EVALCI_COMMIT_SHA=
EVALCI_PR_NUMBER=
EVALCI_PIPELINE_VERSION=

# Evaluation settings
EVALCI_MAX_CONCURRENT_EVALS=5

# Frontend API URL (used by Vite dev server proxy)
VITE_API_URL=http://localhost:8000
